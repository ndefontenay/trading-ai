# Alpaca (stocks) — https://alpaca.markets
ALPACA_API_KEY=your_key_here
ALPACA_SECRET_KEY=your_secret_here
ALPACA_PAPER=true   # set to false for live trading

# Coinbase Advanced (crypto) — https://portal.cdp.coinbase.com
# Only needed for live trading (Phase 5); paper trading is simulated locally.
COINBASE_API_KEY=your_key_here
COINBASE_API_SECRET=your_secret_here
CRYPTO_PAPER=true   # set to false for live trading
